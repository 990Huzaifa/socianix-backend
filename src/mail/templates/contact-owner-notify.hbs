<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="color-scheme" content="light" />
  <title>New Contact Inquiry</title>
</head>
<body style="margin:0;padding:0;background-color:#F8FAFC;font-family:-apple-system,BlinkMacSystemFont,'Segoe UI',Roboto,Helvetica,Arial,sans-serif;-webkit-font-smoothing:antialiased;">
  <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#F8FAFC;padding:40px 16px;">
    <tr>
      <td align="center">
        <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="max-width:560px;background-color:#FFFFFF;border:1px solid rgba(15,23,42,0.08);border-radius:16px;overflow:hidden;">
          <tr>
            <td style="height:4px;background-color:#0D9488;font-size:0;line-height:0;">&nbsp;</td>
          </tr>
          <tr>
            <td style="padding:36px 40px 28px;background-color:#FFFFFF;">
              <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                <tr>
                  <td align="center" style="padding-bottom:28px;">
                    {{#if logoUrl}}
                    <img src="{{logoUrl}}" alt="{{appName}}" width="132" style="display:block;border:0;max-width:132px;height:auto;" />
                    {{else}}
                    <span style="display:inline-block;font-size:20px;font-weight:700;letter-spacing:-0.02em;color:#0D9488;">{{appName}}</span>
                    {{/if}}
                  </td>
                </tr>
                <tr>
                  <td align="center" style="padding-bottom:12px;">
                    <span style="display:inline-block;padding:6px 12px;background-color:#CCFBF1;color:#0F766E;font-size:12px;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;border-radius:999px;">New lead</span>
                  </td>
                </tr>
                <tr>
                  <td align="center" style="padding-bottom:16px;">
                    <h1 style="margin:0;font-size:24px;line-height:1.3;font-weight:700;color:#0F172A;letter-spacing:-0.02em;">New contact inquiry</h1>
                  </td>
                </tr>
                <tr>
                  <td align="center" style="padding-bottom:24px;">
                    <p style="margin:0;font-size:15px;line-height:1.65;color:#64748B;">
                      A new inquiry was submitted on {{appName}}.
                    </p>
                  </td>
                </tr>
                <tr>
                  <td style="padding-bottom:8px;">
                    <table role="presentation" width="100%" cellpadding="0" cellspacing="0" style="background-color:#F0FDFA;border:1px solid rgba(15,23,42,0.08);border-radius:12px;">
                      <tr>
                        <td style="padding:20px 24px;">
                          <p style="margin:0 0 14px;font-size:12px;font-weight:600;letter-spacing:0.04em;text-transform:uppercase;color:#0F766E;">Lead details</p>
                          <table role="presentation" width="100%" cellpadding="0" cellspacing="0">
                            <tr>
                              <td style="padding:0 0 10px;font-size:13px;color:#64748B;width:88px;vertical-align:top;">Name</td>
                              <td style="padding:0 0 10px;font-size:14px;font-weight:600;color:#0F172A;">{{name}}</td>
                            </tr>
                            <tr>
                              <td style="padding:0 0 10px;font-size:13px;color:#64748B;width:88px;vertical-align:top;">Email</td>
                              <td style="padding:0 0 10px;font-size:14px;font-weight:600;color:#0F172A;">{{email}}</td>
                            </tr>
                            <tr>
                              <td style="padding:0 0 10px;font-size:13px;color:#64748B;width:88px;vertical-align:top;">Inquiry</td>
                              <td style="padding:0 0 10px;font-size:14px;font-weight:600;color:#0F172A;">{{inquiry}}</td>
                            </tr>
                            <tr>
                              <td style="padding:0;font-size:13px;color:#64748B;width:88px;vertical-align:top;">Message</td>
                              <td style="padding:0;font-size:14px;line-height:1.6;color:#0F172A;">{{message}}</td>
                            </tr>
                          </table>
                        </td>
                      </tr>
                    </table>
                  </td>
                </tr>
              </table>
            </td>
          </tr>
          <tr>
            <td style="padding:20px 40px 28px;background-color:#F8FAFC;border-top:1px solid rgba(15,23,42,0.08);">
              <p style="margin:0;text-align:center;font-size:12px;line-height:1.6;color:#64748B;">
                © {{year}} {{appName}}. All rights reserved.
              </p>
            </td>
          </tr>
        </table>
      </td>
    </tr>
  </table>
</body>
</html>
