# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=socianix
DB_SSL=false
DB_LOGGING=true

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# OTP
OTP_LENGTH=6
OTP_EXPIRES_IN_MINUTES=10

# App / Mail (third-party API)
APP_NAME=Socianix
APP_URL=http://localhost:3000
MAIL_SERVICE_URL=http://72.60.114.133:8001/send-email
MAIL_API_KEY=
MAIL_SERVICE_MASTER_USER=admin@salesvince.com
MAIL_FROM_NOREPLY=noreply@salesvince.com
MAIL_FROM_SUPPORT=support@salesvince.com
MAIL_FROM_INFO=info@salesvince.com
OWNER_EMAIL=syedhuzaifaali366@gmail.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback
GOOGLE_SCOPES=openid email profile

# Meta OAuth
META_APP_ID=
META_APP_SECRET=
META_REDIRECT_URI=http://localhost:3000/oauth/meta/callback
META_SCOPES=email public_profile

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/oauth/linkedin/callback
LINKEDIN_SCOPES=openid profile email

# Pinterest OAuth
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:3000/oauth/pinterest/callback
PINTEREST_SCOPES=boards:read pins:read user_accounts:read

# TikTok OAuth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
