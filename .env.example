# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=socianix
DB_SSL=false
DB_LOGGING=true

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# Cron / ops (optional; if set, required as header x-cron-secret)
CRON_SECRET=
API_BASE_URL=http://localhost:3000

# OTP
OTP_LENGTH=6
OTP_EXPIRES_IN_MINUTES=10

# App / Mail (third-party API)
APP_NAME=Socianix
APP_URL=http://localhost:3000
MAIL_SERVICE_URL=http://72.60.114.133:8001/send-email
MAIL_API_KEY=
MAIL_SERVICE_MASTER_USER=admin@salesvince.com
MAIL_FROM_NOREPLY=noreply@salesvince.com
MAIL_FROM_SUPPORT=support@salesvince.com
MAIL_FROM_INFO=info@salesvince.com
OWNER_EMAIL=syedhuzaifaali366@gmail.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/business.manage https://www.googleapis.com/auth/youtube.readonly https://www.googleapis.com/auth/youtube.upload

# Meta OAuth (Facebook + Instagram)
METADATA_APP_ID=
METADATA_APP_SECRET=
METADATA_REDIRECT_URI=http://localhost:3000/oauth/meta/callback
METADATA_SCOPES=pages_show_list pages_read_engagement pages_manage_posts instagram_basic instagram_content_publish email

# Threads OAuth
THREAD_APP_ID=
THREAD_API_SECRET=
THREAD_API_URL=http://localhost:3000/oauth/thread/callback
THREAD_SCOPES=threads_basic threads_content_publish

# X (Twitter) OAuth 2.0 + PKCE
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/oauth/x/callback
X_SCOPES=tweet.read users.read offline.access

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/oauth/linkedin/callback
LINKEDIN_SCOPES=openid profile email

# Pinterest OAuth
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:3000/oauth/pinterest/callback
PINTEREST_SCOPES=boards:read pins:read user_accounts:read

# TikTok OAuth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/oauth/tiktok/callback
TIKTOK_SCOPES=user.info.basic
