# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=socianix
DB_SSL=false
DB_LOGGING=true

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d

# OTP
OTP_LENGTH=6
OTP_EXPIRES_IN_MINUTES=10
