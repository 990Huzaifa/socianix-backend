# Application
PORT=3000
NODE_ENV=development

# Database (PostgreSQL)
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_DATABASE=socianix
DB_SSL=false
DB_LOGGING=true

# JWT
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=7d
SOCIAL_TOKEN_ENCRYPTION_KEY=change-me-to-a-separate-long-random-secret

# Admin seeder (npm run seed:admins)
ADMIN_NAME=Super Admin
ADMIN_EMAIL=admin@socianix.com
ADMIN_PASSWORD=Admin@123456
ADMIN_ROLE=superAdmin

# Pusher (realtime post events)
PUSHER_APP_ID=
PUSHER_KEY=
PUSHER_SECRET=
PUSHER_CLUSTER=mt1

# AWS S3
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_REGION=eu-north-1
AWS_S3_BUCKET_NAME=

# Cron / ops (optional; if set, required as header x-cron-secret)
CRON_SECRET=
API_BASE_URL=http://localhost:3000

# OTP
OTP_LENGTH=6
OTP_EXPIRES_IN_MINUTES=10

# App / Mail (Brevo)
APP_NAME=Socianix
APP_URL=http://localhost:3000
LOGOS_URL=https://media.socialsyncc.com/logo.png
OAUTH_CALLBACK_DEEPLINK=socialsyncc://oauth/callback
MAIL_API_KEY=
MAIL_FROM_NOREPLY=noreply@example.com
MAIL_FROM_SUPPORT=support@example.com
MAIL_FROM_INFO=info@example.com
OWNER_EMAIL=owner@example.com

# Google OAuth
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:3000/oauth/google/callback
GOOGLE_SCOPES=openid email profile https://www.googleapis.com/auth/business.manage https://www.googleapis.com/auth/youtube.readonly https://www.googleapis.com/auth/youtube.upload

# Social login (Google + Apple ID tokens from mobile/web clients)
GOOGLE_AUTH_CLIENT_IDS=
APPLE_AUTH_CLIENT_ID=

# Meta OAuth (Facebook + Instagram)
METADATA_APP_ID=
METADATA_APP_SECRET=
METADATA_REDIRECT_URI=http://localhost:3000/oauth/meta/callback
METADATA_SCOPES=pages_show_list pages_read_engagement pages_manage_posts instagram_basic instagram_content_publish email

# Threads OAuth
THREAD_APP_ID=
THREAD_API_SECRET=
THREAD_API_URL=http://localhost:3000/oauth/thread/callback
THREAD_SCOPES="threads_basic threads_content_publish"

# X (Twitter) OAuth 2.0 + PKCE
X_CLIENT_ID=
X_CLIENT_SECRET=
X_REDIRECT_URI=http://localhost:3000/oauth/x/callback
X_SCOPES=tweet.read users.read offline.access

# LinkedIn OAuth
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_REDIRECT_URI=http://localhost:3000/oauth/linkedin/callback
LINKEDIN_SCOPES="openid profile email w_member_social w_organization_social r_organization_social offline_access"

# Pinterest OAuth
PINTEREST_APP_ID=
PINTEREST_APP_SECRET=
PINTEREST_REDIRECT_URI=http://localhost:3000/oauth/pinterest/callback
PINTEREST_SCOPES=boards:read pins:read pins:write user_accounts:read
# Trial apps must use sandbox (`true`). Set `false` after Standard/production access.
PINTEREST_USE_SANDBOX=true

# TikTok OAuth
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
TIKTOK_REDIRECT_URI=http://localhost:3000/oauth/tiktok/callback
TIKTOK_SCOPES=user.info.basic,video.publish

# Snapchat OAuth
SNAPCHAT_CLIENT_ID=
SNAPCHAT_CLIENT_SECRET=
SNAPCHAT_REDIRECT_URI=http://localhost:3000/oauth/snapchat/callback
SNAPCHAT_SCOPES=snapchat-marketing-api
